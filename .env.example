# Database
DATABASE_URL="postgresql://gitflow:password@localhost:5435/vault?schema=public"

# Redis (BullMQ / Queue)
REDIS_URL="redis://localhost:6379"

# GitHub App Configuration
GITHUB_APP_ID="YOUR_APP_ID"
GITHUB_WEBHOOK_SECRET="your_webhook_secret_here"
# Note: Keep the literal '\n' characters in your private key string if putting it on one line, 
# or use multiline quotes if your environment supports it.
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEA..."

# Application
PORT=3001
NODE_ENV="development"

# Security hardening
# Comma-separated frontend origins for CORS/WS checks in Sentinel.
# Example: "http://localhost:3000,https://cockpit.example.com"
ALLOWED_ORIGINS="http://localhost:3000"

# Comma-separated GitHub event names allowed at ingress.
ALLOWED_GITHUB_EVENTS="pull_request,pull_request_review"

# Webhook ingress controls
WEBHOOK_BODY_LIMIT="1mb"
WEBHOOK_RATE_LIMIT_WINDOW_MS=900000
WEBHOOK_RATE_LIMIT_MAX=300

# Optional production read token for Cockpit repository API route.
COCKPIT_READ_API_TOKEN=""
