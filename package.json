{
  "name": "gitflow",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:prod:full": "npm audit --omit=dev",
    "ci:check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run audit:prod",
    "version:beta": "node scripts/bump-beta-version.js",
    "version:beta:show": "node -e \"console.log(require('fs').readFileSync('BETA_VERSION','utf8').trim())\"",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "sync": "npx ts-node scripts/sync.ts",
    "check:events": "npx ts-node scripts/check-events.ts",
    "db:push": "turbo run db:push",
    "db:generate": "turbo run db:generate"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^1.13.2",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "lodash": "4.18.1"
  }
}
